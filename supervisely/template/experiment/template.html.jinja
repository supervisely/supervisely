<div class="experiment-body">

    <sly-style>
        .experiment-body h1 {
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 5px;
        }
        .experiment-body .sly-markdown-widget .markdown-body {
        padding: 0;
        font-family: inherit;
        }
        .experiment-body .sly-markdown-widget .markdown-body h2 {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 0px;
        border: 0;
        }
        .experiment-body .sly-markdown-widget .markdown-body h3 {
        color: #949bab;
        font-size: 18px;
        margin-bottom: 7px;
        }
        .experiment-body .sly-markdown-widget .markdown-body p {
        margin-bottom: 12px;
        }

        .experiment-body .section {
        margin-bottom: 30px;
        scroll-margin-top: 20px;
        padding-top: 10px;
        }

        .experiment-body .main-content {
        flex-grow: 1;
        }

        .experiment-body table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
        }
        .experiment-body table th,
        .experiment-body table td {
        border: 1px solid #e0e0e0;
        padding: 8px 12px;
        text-align: left;
        }
        .experiment-body table th {
        background-color: #f4f7fb;
        }

        html {
        scroll-behavior: smooth;
        }

        .experiment-body .info-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
        }

        .experiment-body .info-table td {
        padding: 6px 8px;
        border-bottom: 1px solid #e2e8f0;
        }

        .experiment-body .info-table td:first-child {
        width: 40%;
        color: #374151;
        }

        .experiment-body .info-table td:last-child {
        color: #6b7280;
        }

        .experiment-body .quick-actions-section {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        height: 100%;
        display: flex;
        flex-direction: column;
        }

        .experiment-body .quick-actions-section h2 {
        margin: 0 0 16px 0;
        font-size: 20px;
        font-weight: 600;
        color: #1a202c;
        }

        .experiment-body .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-grow: 1;
        justify-content: flex-start;
        }

        .experiment-body .action-button {
        display: flex;
        align-items: center;
        padding: 12px 14px;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
        border: 1px solid transparent;
        gap: 12px;
        }

        .experiment-body .action-button.primary {
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        color: white;
        box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
        }

        .experiment-body .action-button.primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }

        .experiment-body .action-button.secondary {
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        color: #475569;
        border: 1px solid #e2e8f0;
        }

        .experiment-body .action-button.secondary:hover {
        background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .experiment-body .action-button.tertiary {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        color: #92400e;
        border: 1px solid #fde68a;
        }

        .experiment-body .action-button.tertiary:hover {
        background: linear-gradient(135deg, #fde68a 0%, #fcd34d 100%);
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(251, 191, 36, 0.3);
        }

        .experiment-body .button-icon {
        font-size: 20px;
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.1);
        border-radius: 6px;
        }

        .experiment-body .action-button.secondary .button-icon,
        .experiment-body .action-button.tertiary .button-icon {
        background: rgba(0,0,0,0.05);
        }

        .experiment-body .button-content {
        flex: 1;
        text-align: left;
        }

        .experiment-body .button-title {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 2px;
        }

        .experiment-body .button-description {
        font-size: 12px;
        opacity: 0.8;
        }

        .experiment-body details {
        border-radius: 6px;
        overflow: hidden;
        margin-bottom: 20px;
        }
        .experiment-body details summary {
        padding: 12px 15px;
        background-color: #f4f7fb;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        transition: background-color 0.2s;
        }
        .experiment-body details summary:hover {
        background-color: #e6edf7;
        }
        .experiment-body details[open] summary {
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
        margin-bottom: 0;
        }

        /* Experiment Header Layout */
        .experiment-header-layout {
        display: grid !important;
        grid-template-columns: 1fr 350px !important;
        grid-template-rows: auto !important;
        gap: 30px !important;
        margin-bottom: 30px !important;
        align-items: stretch !important;
        width: 100% !important;
        box-sizing: border-box !important;
        }

        .experiment-body .experiment-header-layout {
        display: grid !important;
        grid-template-columns: 1fr 350px !important;
        grid-template-rows: auto !important;
        gap: 30px !important;
        margin-bottom: 30px !important;
        align-items: stretch !important;
        width: 100% !important;
        box-sizing: border-box !important;
        }

        /* Ensure child elements don't override grid behavior */
        .experiment-header-layout > .key-info-section {
        grid-column: 1 !important;
        grid-row: 1 !important;
        }

        .experiment-header-layout > .quick-actions-section {
        grid-column: 2 !important;
        grid-row: 1 !important;
        }

        /* Inner grid layout for key-info-section */
        .info-grid-layout {
        display: grid !important;
        grid-template-columns: 1fr 1fr !important;
        gap: 25px !important;
        width: 100% !important;
        }

        .main-info-column {
        grid-column: 1 !important;
        }

        .experiment-body .key-info-section {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .experiment-body .key-info-section h2 {
        margin: 0 0 16px 0;
        font-size: 20px;
        font-weight: 600;
        color: #1a202c;
        }

        .experiment-body .key-info-section h3 {
        margin: 20px 0 8px 0;
        font-size: 16px;
        font-weight: 600;
        color: #374151;
        }

        .prediction-gallery {
        margin-bottom: 20px;
        }
    </sly-style>

    <!-- Sidebar navigation -->
    <sly-iw-sidebar
        :options="{ height: 'calc(100vh - 130px)', clearMainPanelPaddings: true, leftSided: false, disableResize: true, sidebarWidth: 300 }">
        <div slot="sidebar">
            {% autosidebar %}
        </div>

        <!-- Main content -->
        <div class="main-content markdown-body">
            {% markdown %}
            {% include "experiment.md.jinja" %}
            {% endmarkdown %}
        </div>
    </sly-iw-sidebar>

</div>