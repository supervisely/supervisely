    </sly-style>

    <!-- Sidebar navigation -->
    <sly-iw-sidebar
        :options="{ height: 'calc(100vh - 130px)', clearMainPanelPaddings: true, leftSided: false, disableResize: true, sidebarWidth: 300 }">
        <div slot="sidebar">
            {% autosidebar %}
        </div>

        <!-- Main content -->
        <div class="main-content markdown-body">
            {% markdown %}
            {% include "experiment.md.jinja" %}
            {% endmarkdown %}
        </div>
    </sly-iw-sidebar>

</div>