<sly-style>
    /* Experiment Header Layout */
    .experiment-header-layout {
    display: grid;
    grid-template-columns: 1fr 200px 300px;
    grid-template-rows: auto;
    gap: 20px;
    margin-bottom: 30px;
    align-items: stretch;
    width: 100%;
    box-sizing: border-box;
    }

    .experiment-body .experiment-header-layout {
    display: grid;
    grid-template-columns: 1fr 200px 300px;
    grid-template-rows: auto;
    gap: 20px;
    margin-bottom: 30px;
    align-items: stretch;
    width: 100%;
    box-sizing: border-box;
    }

    /* Grid positioning for three columns */
    .experiment-header-layout > .key-info-section {
    grid-column: 1;
    grid-row: 1;
    }

    .experiment-header-layout > .metrics-highlight-section {
    grid-column: 2;
    grid-row: 1;
    }

    .experiment-header-layout > .quick-actions-section {
    grid-column: 3;
    grid-row: 1;
    }

    /* Remove inner grid layout for key-info-section */
    .info-grid-layout {
    display: block;
    width: 100%;
    }

    .main-info-column {
    width: 100%;
    }

    .experiment-body .key-info-section {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .experiment-body .key-info-section h2 {
    margin: 0 0 16px 0;
    font-size: 20px;
    font-weight: 600;
    color: #1a202c;
    }

    .experiment-body .key-info-section h3 {
    margin: 20px 0 8px 0;
    font-size: 16px;
    font-weight: 600;
    color: #374151;
    }

    .project-link {
    color: #3b82f6;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
    }

    .project-link:hover {
    color: #1d4ed8;
    text-decoration: underline;
    }

    /* New styles for experiment status */
    .experiment-status {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e2e8f0;
    }

    .status-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    }

    .status-text {
    font-weight: 600;
    font-size: 16px;
    }

    .experiment-date {
    color: #6b7280;
    font-size: 14px;
    }

    /* Metrics highlight section styles */
    .metrics-highlight-section {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    gap: 10px;
    }

    .metric-card {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 12px;
    text-align: center;
    transition: all 0.2s ease;
    }

    .metric-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .metric-card.primary {
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    color: white;
    border-color: #3b82f6;
    }

    .metric-card.primary.excellent {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    border-color: #10b981;
    }

    .metric-card.primary.good {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    border-color: #f59e0b;
    }

    .metric-card.primary.average {
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    border-color: #f97316;
    }

    .metric-card.primary.poor {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    border-color: #ef4444;
    }

    .metric-value {
    font-size: 20px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 2px;
    }

    .metric-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.8;
    }

    .metric-subtitle {
    font-size: 8px;
    margin-top: 1px;
    opacity: 0.7;
    }

    /* Enhanced styles for left card */
    .info-cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-bottom: 16px;
    }

    .info-card {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 10px;
    text-align: center;
    transition: all 0.2s ease;
    }

    .info-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .info-card.highlighted {
    background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
    border-color: #0ea5e9;
    }

    .info-card-icon {
    font-size: 14px;
    margin-bottom: 6px;
    display: block;
    }

    .info-card-value {
    font-size: 14px;
    font-weight: 600;
    color: #374151;
    margin-bottom: 2px;
    }

    .info-card-value.model-name {
    color: #3b82f6;
    font-weight: 700;
    }

    .info-card-label {
    font-size: 11px;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
    }

    /* Artifacts section */
    .artifacts-section {
    background: linear-gradient(135deg, #fef7ff 0%, #f3e8ff 100%);
    border: 1px solid #d8b4fe;
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 16px;
    }

    .artifacts-section h4 {
    margin: 0 0 10px 0;
    font-size: 14px;
    font-weight: 600;
    color: #7c3aed;
    display: flex;
    align-items: center;
    gap: 6px;
    }

    .artifact-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 6px;
    }

    .artifact-link {
    display: flex;
    align-items: center;
    padding: 6px 8px;
    background: white;
    border: 1px solid #d8b4fe;
    border-radius: 4px;
    text-decoration: none;
    color: #7c3aed;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease;
    gap: 8px;
    }

    .artifact-link:hover {
    background: linear-gradient(135deg, #7c3aed 0%, #6366f1 100%);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(124, 58, 237, 0.3);
    }

    .artifact-icon {
    font-size: 12px;
    width: 16px;
    text-align: center;
    }

    .artifact-text {
    flex: 1;
    text-align: left;
    }

    .artifact-size {
    font-size: 14px;
    opacity: 0.7;
    }

    /* Technical details section */
    .tech-details-section {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border: 1px solid #86efac;
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 16px;
    }

    .tech-details-section h4 {
    margin: 0 0 10px 0;
    font-size: 14px;
    font-weight: 600;
    color: #166534;
    display: flex;
    align-items: center;
    gap: 6px;
    }

    .tech-details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 6px;
    }

    .tech-detail-item {
    background: white;
    border: 1px solid #86efac;
    border-radius: 4px;
    padding: 8px 6px;
    text-align: center;
    }

    .tech-detail-value {
    font-size: 14px;
    font-weight: 600;
    color: #166534;
    margin-bottom: 2px;
    }

    .tech-detail-label {
    font-size: 11px;
    color: #16a34a;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    font-weight: 500;
    }

    /* Integrated Quick Access Section */
    .integrated-quick-access {
    background: linear-gradient(135deg, #fff7ed 0%, #fed7aa 100%);
    border: 1px solid #fdba74;
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 16px;
    }

    .integrated-quick-access h4 {
    margin: 0 0 10px 0;
    font-size: 14px;
    font-weight: 600;
    color: #c2410c;
    display: flex;
    align-items: center;
    gap: 6px;
    }

    .integrated-quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 6px;
    }

    .integrated-quick-link {
    display: flex;
    align-items: center;
    padding: 6px 8px;
    background: white;
    border: 1px solid #fdba74;
    border-radius: 4px;
    text-decoration: none;
    color: #c2410c;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease;
    gap: 8px;
    }

    .integrated-quick-link:hover {
    background: linear-gradient(135deg, #ea580c 0%, #dc2626 100%);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(234, 88, 12, 0.3);
    }

    .integrated-quick-icon {
    font-size: 12px;
    width: 16px;
    text-align: center;
    }

    .integrated-quick-text {
    flex: 1;
    text-align: left;
    font-size: 14px;
    }

    .experiment-body .quick-actions-section {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    height: 100%;
    display: flex;
    flex-direction: column;
    }

    .experiment-body .quick-actions-section h2 {
    margin: 0 0 16px 0;
    font-size: 18px;
    font-weight: 600;
    color: #1a202c;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 8px;
    }

    .experiment-body .action-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
    justify-content: flex-start;
    }

    .experiment-body .action-button {
    display: flex;
    align-items: center;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid transparent;
    gap: 12px;
    }

    .experiment-body .action-button.primary {
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    color: white;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
    }

    .experiment-body .action-button.primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
    }

    .experiment-body .action-button.secondary {
    background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    color: #475569;
    border: 1px solid #e2e8f0;
    }

    .experiment-body .action-button.secondary:hover {
    background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .experiment-body .action-button.tertiary {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    color: #92400e;
    border: 1px solid #fde68a;
    }

    .experiment-body .action-button.tertiary:hover {
    background: linear-gradient(135deg, #fde68a 0%, #fcd34d 100%);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(251, 191, 36, 0.3);
    }

    .experiment-body .button-icon {
    font-size: 20px;
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    border-radius: 6px;
    }

    .experiment-body .action-button.secondary .button-icon,
    .experiment-body .action-button.tertiary .button-icon {
    background: rgba(0,0,0,0.05);
    }

    .experiment-body .button-content {
    flex: 1;
    text-align: left;
    }

    .experiment-body .button-title {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 2px;
    }

    .experiment-body .button-description {
    font-size: 12px;
    opacity: 0.8;
    }
</sly-style>

<!-- Experiment Header -->
<div class="experiment-header-layout">
    <div class="key-info-section">

        <!-- Status indicator -->
        <div class="experiment-status">
            <div class="status-indicator status-completed">
                <span class="status-text">{{ experiment.name }}</span>
            </div>
            <div class="experiment-date">{{ experiment.date }}</div>
        </div>

        <div class="info-grid-layout">
            <div class="main-info-column">

                <!-- Info Cards Grid -->
                <div class="info-cards-grid">
                    <div class="info-card highlighted">
                        <div class="info-card-value model-name">{{ experiment.model_name }}</div>
                        <div class="info-card-label">🤖 Model</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-value">{{ experiment.framework_name }}</div>
                        <div class="info-card-label">🔧 Framework</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-value">{{ experiment.task_name }}</div>
                        <div class="info-card-label">🎯 Task</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-value"><a href="{{ project.link }}" target="_blank"
                                class="project-link">{{ project.name }}</a>
                        </div>
                        <div class="info-card-label">📁 Project</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-value">{{ project.classes_count }} classes</div>
                        <div class="info-card-label">🏷️ Classes</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-value">{{ project.train_size }} train / {{ project.val_size }} val
                        </div>
                        <div class="info-card-label">📊 Split</div>
                    </div>
                </div>

                <!-- Artifacts Section -->
                <div class="artifacts-section">
                    <h4>📦 Model Artifacts</h4>
                    <div class="artifact-links">
                        <a href="{{ artifacts.best_checkpoint.url }}" class="artifact-link"
                            download="{{ artifacts.best_checkpoint.name }}">
                            <span class="artifact-icon">🔥</span>
                            <span class="artifact-text">{{ artifacts.best_checkpoint.name }}</span>
                            <span class="artifact-size">{{ artifacts.best_checkpoint.size }}</span>
                        </a>
                        {% if artifacts.onnx_checkpoint.name %}
                        <a href="{{ artifacts.onnx_checkpoint.url }}" class="artifact-link"
                            download="{{ artifacts.onnx_checkpoint.name }}">
                            <span class="artifact-icon">📦</span>
                            <span class="artifact-text">{{ artifacts.onnx_checkpoint.name }}</span>
                            <span class="artifact-size">{{ artifacts.onnx_checkpoint.size }}</span>
                        </a>
                        {% endif %}
                        {% if artifacts.trt_checkpoint.name %}
                        <a href="{{ artifacts.trt_checkpoint.url }}" class="artifact-link"
                            download="{{ artifacts.trt_checkpoint.name }}">
                            <span class="artifact-icon">⚡</span>
                            <span class="artifact-text">{{ artifacts.trt_checkpoint.name }}</span>
                            <span class="artifact-size">{{ artifacts.trt_checkpoint.size }}</span>
                        </a>
                        {% endif %}
                    </div>
                </div>

                <!-- Technical Details Section -->
                <div class="tech-details-section">
                    <h4>⚙️ Technical Details</h4>
                    <div class="tech-details-grid">
                        <div class="tech-detail-item">
                            <div class="tech-detail-value"><a href="{{ experiment.agent.link }}" target="_blank">{{
                                    experiment.agent.name }}</a></div>
                            <div class="tech-detail-label">Agent</div>
                        </div>
                        <div class="tech-detail-item">
                            <div class="tech-detail-value">{{ experiment.device if experiment.device else "N/A" }}</div>
                            <div class="tech-detail-label">Device</div>
                        </div>
                        <div class="tech-detail-item">
                            <div class="tech-detail-value">{{ experiment.training_duration if
                                experiment.training_duration else "N/A" }}</div>
                            <div class="tech-detail-label">Training Time</div>
                        </div>
                    </div>
                </div>

                <!-- Integrated Quick Access Links -->
                <div class="integrated-quick-access">
                    <h4>🔗 Quick Access</h4>
                    <div class="integrated-quick-links">
                        <a href="{{ links.training_session.url }}" target="_blank" class="integrated-quick-link">
                            <span class="integrated-quick-icon">🎓</span>
                            <span class="integrated-quick-text">Training Session</span>
                        </a>
                        <a href="{{ links.tensorboard_logs.url }}" target="_blank" class="integrated-quick-link">
                            <span class="integrated-quick-icon">📈</span>
                            <span class="integrated-quick-text">Training Logs</span>
                        </a>
                        <a href="{{ links.team_files.url }}" target="_blank" class="integrated-quick-link">
                            <span class="integrated-quick-icon">📂</span>
                            <span class="integrated-quick-text">Artifacts folder</span>
                        </a>
                        {% if links.evaluation_report.id %}
                        <a href="{{ links.evaluation_report.url }}" target="_blank" class="integrated-quick-link">
                            <span class="integrated-quick-icon">📊</span>
                            <span class="integrated-quick-text">Evaluation Report</span>
                        </a>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Separate metrics highlights section - only show if we have metrics -->
    {% if benchmark.primary_metric.name or benchmark.display_metrics %}
    <div class="metrics-highlight-section">

        <div class="experiment-status">
            <div class="status-indicator status-completed">
                <span class="status-text">Metrics</span>
            </div>
        </div>

        {% if benchmark.primary_metric.name %}
        {% set primary_value = benchmark.primary_metric.value %}
        {% if primary_value >= 0.9 %}
        {% set color_class = "excellent" %}
        {% elif primary_value >= 0.7 %}
        {% set color_class = "good" %}
        {% elif primary_value >= 0.5 %}
        {% set color_class = "average" %}
        {% else %}
        {% set color_class = "poor" %}
        {% endif %}
        <div class="metric-card primary {{ color_class }}">
            <div class="metric-value">{{ "%.1f"|format(benchmark.primary_metric.value * 100) }}%</div>
            <div class="metric-label">{{ benchmark.primary_metric.name }}</div>
            <div class="metric-subtitle">Primary Metric</div>
        </div>
        {% endif %}

        {% if benchmark.display_metrics %}
        {% for metric_name, metric_value in benchmark.display_metrics %}
        <div class="metric-card">
            <div class="metric-value">
                {% if metric_value is number and metric_value <= 1 %} {{ "%.1f" |format(metric_value * 100) }}% {% else
                    %} {{ "%.3f" |format(metric_value) }} {% endif %} </div>
                    <div class="metric-label">{{ metric_name.replace('_', ' ').title() }}</div>
            </div>
            {% endfor %}
            {% endif %}

        </div>
        {% else %}
        <!-- No metrics placeholder -->
        <div class="metrics-highlight-section">
            <div class="experiment-status">
                <div class="status-indicator status-completed">
                    <span class="status-text">Metrics</span>
                </div>
            </div>
            <div class="metric-card">
                <div class="metric-value">N/A</div>
                <div class="metric-label">No Evaluation</div>
                <div class="metric-subtitle">Metrics not available</div>
            </div>
        </div>
        {% endif %}

        <div class="quick-actions-section">

            <div class="experiment-status">
                <div class="status-indicator status-completed">
                    <span class="status-text">Actions</span>
                </div>
            </div>

            <div class="action-buttons">
                <a href="{{ env.server_address }}/ecosystem/apps/{{ links.app.serve }}" class="action-button primary">
                    <div class="button-icon">🚀</div>
                    <div class="button-content">
                        <div class="button-title">Deploy</div>
                        <div class="button-description">Deploy to Supervisely</div>
                    </div>
                </a>

                <a href="{{ env.server_address }}/ecosystem/apps/{{ links.app.apply_nn_to_images }}"
                    class="action-button secondary">
                    <div class="button-icon">⚡</div>
                    <div class="button-content">
                        <div class="button-title">Apply</div>
                        <div class="button-description">Apply model to Supervisely project</div>
                    </div>
                </a>

                <a href="{{ artifacts.best_checkpoint.url }}" class="action-button secondary" download>
                    <div class="button-icon">📥</div>
                    <div class="button-content">
                        <div class="button-title">Download</div>
                        <div class="button-description">Best checkpoint</div>
                    </div>
                </a>

                <a href="{{ env.server_address }}/ecosystem/apps/{{ links.app.train }}" class="action-button tertiary">
                    <div class="button-icon">🔄</div>
                    <div class="button-content">
                        <div class="button-title">Fine-tune</div>
                        <div class="button-description">Continue training</div>
                    </div>
                </a>

                <a href="{{ env.server_address }}/ecosystem/apps/{{ links.app.train }}" class="action-button secondary">
                    <div class="button-icon">🎯</div>
                    <div class="button-content">
                        <div class="button-title">Train Again</div>
                        <div class="button-description">Start new training with the same data and hyperparameters</div>
                    </div>
                </a>

            </div>
        </div>

    </div>